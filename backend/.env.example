SUPABASE_URL=https://your-project.supabase.co
# Server-side only. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Production marketing origins. Add localhost origins locally if needed.
CORS_ALLOWED_ORIGINS=https://getclavix.com,https://www.getclavix.com

MINIMAX_API_KEY=sk-cp-your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.io/v1

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# App Store ID for Clavix. Override only if the App Store Connect app changes.
APP_STORE_APP_APPLE_ID=6775920073
APP_STORE_BUNDLE_ID=com.clavisdev.portfolioassistant
APP_STORE_PRODUCT_IDS=clavix_pro_monthly
APP_STORE_ONLINE_CHECKS=true
# Secure launch default. Set false only for an intentional emergency rollback.
HARD_PAYWALL_ENABLED=true

FINNHUB_API_KEY=your-finnhub-api-key

APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_KEY_PATH=/app/apns/apns.p8

POLYGON_API_KEY=your-polygon-api-key
